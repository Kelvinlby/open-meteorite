{
  "schemaVersion": 1,
  "id": "open-meteorite",
  "version": "${version}",
  "name": "Open Meteorite",
  "description": "An addon for Meteor Client that adds performance-oriented rendering modules.",
  "authors": [
    "Kelvin_LBY",
    "HUI_73rd",
    "Toaru",
    "liooo"
  ],
  "contact": {
    "sources": "https://github.com/Kelvinlby/open-meteorite"
  },
  "icon": "assets/open-meteorite/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "addon.meteorite.open.OpenMeteorite"
    ]
  },
  "mixins": [
    "open-meteorite.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,25,25",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=21",
    "minecraft": [
      "1.21.4",
      "1.21.11"
    ],
    "meteor-client": "*"
  }
}
