{
  "schemaVersion": 1,
  "id": "open-meteorite",
  "version": "${version}",
  "name": "Open Meteorite",
  "description": "A Meteor Client addon.",
  "authors": [
    "kelvinlby"
  ],
  "contact": {
    "sources": "https://github.com/kelvinlby/open-meteorite"
  },
  "icon": "assets/open-meteorite/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "addon.kelvinlby.openmeteorite.OpenMeteorite"
    ]
  },
  "mixins": [
    "open-meteorite.mixins.json"
  ],
  "accessWidener": "open-meteorite.accesswidener",
  "custom": {
    "meteor-client:color": "225,25,25",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=${jdk_version}",
    "minecraft": "${minecraft_version}",
    "meteor-client": "*"
  }
}
